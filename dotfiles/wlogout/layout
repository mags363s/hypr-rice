{
    "label": "lock",
    "action": " ~/.config/wlogout/confirm.sh 'hyprlock -c ~/.config/hypr/hyprlock/hyprlock.conf' 'bloquear'",
    "text": "Bloquear",
    "keybind": "l"
}
{
    "label": "logout",
    "action": "~/.config/wlogout/confirm.sh 'hyprctl dispatch exit' 'cerrar sesión'",
    "text": "Cerrar Sesion",
    "keybind": "e"
}
{
    "label": "reboot",
    "action": "~/.config/wlogout/confirm.sh 'systemctl reboot' 'reiniciar'",
    "text": "Reiniciar",
    "keybind": "r"
}
{
    "label": "shutdown",
    "action": "~/.config/wlogout/confirm.sh 'systemctl poweroff' 'apagar'",
    "text": "Apagar",
    "keybind": "s"
}
